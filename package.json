function Badge({ children }) {
  return <span className="rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-800">{children}</span>;
}

function Stat({ number, label }) {
  return (
    <div className="rounded-2xl bg-white/10 p-4 ring-1 ring-white/10">
      <p className="text-2xl font-extrabold">{number}</p>
      <p className="mt-1 text-sm text-emerald-50">{label}</p>
